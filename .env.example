# Create accoun YourBot and get token in profile 
# String "Bot" in login ending required. https://arena.grandgames.net/en/signup
TOKEN="jwttokenhere21312asdasdasds"

# Show logging messages in console
DEBUG="true"

# If you wan't disable training mode use true
NO_TRAIN="false" 

# 0 - use only for debug. System will not create emty tables for your bot. Use 1-5 for production.
MAX_TABLES=0

# Which AI implementation to load. Must match a key in src/ai/registry.ts.
# Available: CarcaBot (default, strong), RandomMove (baseline / debug)
AI="CarcaBot"